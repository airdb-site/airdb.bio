---
import '../styles/global.css';
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/600.css';
import '@fontsource/fraunces/400-italic.css';
import '@fontsource/fraunces/600-italic.css';
import '@fontsource/ibm-plex-sans/300.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-mono/400.css';

type Lang = 'zh' | 'en';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  /** 不带语言前缀的路径，如 '/'，用于 canonical / hreflang / 语言切换 */
  path?: string;
}

const SITE = 'https://airdb.bio';

const {
  lang = 'zh',
  path = '/',
  title = lang === 'zh' ? 'airdb.bio — 生物圈' : 'airdb.bio — The Biosphere',
  description = lang === 'zh'
    ? 'bio = 生命。生命科学 · 生平印记 —— airdb 站群的生物圈。'
    : 'bio means life: life science and biographies — the biosphere of the airdb constellation.',
} = Astro.props;

const zhUrl = SITE + path;
const enUrl = SITE + '/en' + (path === '/' ? '/' : path);
const canonical = lang === 'zh' ? zhUrl : enUrl;
const switchHref = lang === 'zh' ? '/en' + (path === '/' ? '/' : path) : path;
const home = lang === 'zh' ? '/' : '/en/';

const nav =
  lang === 'zh'
    ? [
        { href: '#root', label: '词根', sub: 'Root' },
        { href: '#science', label: '生命科学', sub: 'Science' },
        { href: '#biography', label: '生平印记', sub: 'Bio' },
        { href: '#family', label: '站群', sub: 'Sites' },
      ]
    : [
        { href: '#root', label: 'Root', sub: '词根' },
        { href: '#science', label: 'Science', sub: '生命科学' },
        { href: '#biography', label: 'Bio', sub: '生平印记' },
        { href: '#family', label: 'Sites', sub: '站群' },
      ];

const F =
  lang === 'zh'
    ? {
        headline: '生命自会找到出路。',
        mono: 'BIO = LIFE. LIFE FINDS A WAY.',
        copyright: '生物行业 · 个人生平',
      }
    : {
        headline: 'Life finds a way.',
        mono: '生命自会找到出路。',
        copyright: 'BIOLOGY · BIOGRAPHY',
      };
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:site_name" content="airdb.bio" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/og.png`} />
  </head>
  <body>
    <header
      class="fixed top-0 right-0 left-0 z-50 border-b border-line bg-ground/80 backdrop-blur-md"
    >
      <div
        class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-10"
      >
        <a href={home} class="group flex items-baseline gap-2.5">
          <span class="font-display text-lg text-ink"
            >airdb<em class="text-leaf">.bio</em></span
          >
          <span
            class="text-xs tracking-[0.3em] text-ink-soft transition-colors group-hover:text-leaf"
            >生物圈</span
          >
        </a>
        <nav class="flex items-center gap-4 md:gap-7">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="group hidden items-baseline gap-2 text-sm text-ink-soft transition-colors hover:text-leaf sm:flex"
              >
                <span class="tracking-[0.12em]">{item.label}</span>
                <span class="hidden font-mono text-[0.6rem] tracking-[0.2em] text-ink-soft/60 uppercase transition-colors group-hover:text-pollen lg:inline">
                  {item.sub}
                </span>
              </a>
            ))
          }
          <a
            href={switchHref}
            class="border border-line px-2.5 py-1 font-mono text-[0.65rem] tracking-[0.2em] text-ink-soft transition-all hover:border-leaf hover:text-leaf"
            aria-label={lang === 'zh' ? 'Switch to English' : '切换到中文'}
          >
            {lang === 'zh' ? 'EN' : '中'}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-line bg-ground-2">
      <div class="mx-auto max-w-6xl px-6 py-16 md:px-10">
        <p class="font-display text-xl text-ink md:text-2xl">
          {F.headline}
        </p>
        <p class="mt-3 font-mono text-xs tracking-[0.3em] text-ink-soft">
          {F.mono}
        </p>

        <div
          class="mt-12 flex flex-col justify-between gap-6 md:flex-row md:items-end"
        >
          <div
            class="flex flex-wrap gap-x-8 gap-y-3 font-mono text-xs tracking-[0.2em] text-ink-soft"
          >
            <a
              href="https://github.com/airdb-site"
              target="_blank"
              rel="noopener"
              class="transition-colors hover:text-leaf">GITHUB ↗</a
            >
            <a
              href="https://airdb.space"
              rel="noopener"
              class="transition-colors hover:text-leaf">AIRDB.SPACE ↗</a
            >
            <a
              href="mailto:info@airdb.com"
              class="transition-colors hover:text-pollen">INFO@AIRDB.COM</a
            >
          </div>
          <p class="font-mono text-[0.65rem] tracking-[0.2em] text-ink-soft">
            © {new Date().getFullYear()} AIRDB.BIO — {F.copyright}
          </p>
        </div>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
